HOME_ASSISTANT_URL=http://homeassistant:8123
ACCESS_TOKEN=replace_with_home_assistant_long_lived_token
PORT=10000
LAYOUT_PATH=/data/layout.yaml
PUBLIC_BASE_URL=http://homeassistant.local:10000
REFRESH_INTERVAL_SECONDS=900
TERMINUS_API_URL=http://terminus:2300
TERMINUS_LOGIN=
TERMINUS_PASSWORD=
TERMINUS_ACCESS_TOKEN=replace_with_terminus_jwt
TERMINUS_REFRESH_TOKEN=
TERMINUS_MODE=byos-uri
TERMINUS_MODEL_ID=1
TERMINUS_SCREEN_ID=
TERMINUS_SCREEN_NAME=ha-sleep-weather
TERMINUS_SCREEN_LABEL=Sleep + Weather
TERMINUS_PLAYLIST_ID=
TERMINUS_WEBHOOK_URL=

# Settings GUI auth (optional). When set, mutating layout, refresh, settings,
# and /api/terminus/* requests require `Authorization: Bearer <SETTINGS_TOKEN>`.
# The /editor page accepts `?token=<SETTINGS_TOKEN>` and stores it in sessionStorage.
# If unset, mutations are allowed with a logged warning (dev mode only).
# SETTINGS_TOKEN=

# Allow mutating settings endpoints without a token (dev only). Leave unset in production.
# ALLOW_NO_AUTH=1
